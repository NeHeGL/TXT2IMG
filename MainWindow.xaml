<Window
    x:Class="TXT2IMG.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:TXT2IMG"
    mc:Ignorable="d"
    Title="TXT2IMG">
    <Grid Padding="24">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FF15141A" Offset="0" />
                <GradientStop Color="#FF1E1D26" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Vertical" Grid.Row="0">
            <TextBlock Text="TXT2IMG" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TitleGradientBrush}" />
            <TextBlock Text="Generate images in any style and copy them straight to your clipboard." Foreground="{StaticResource SubtleTextBrush}" Margin="0,6,0,0" FontSize="14" />
        </StackPanel>

        <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="16" Padding="16" Grid.Row="1" Margin="0,20,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PromptTextBox" Grid.Column="0" Height="44" PlaceholderText="Describe what you want, then press Enter" Background="#FF2A2939" Foreground="White" PlaceholderForeground="#FF9A99AC" BorderBrush="{StaticResource CardBorderBrush}" VerticalAlignment="Center" FontSize="15" KeyDown="PromptTextBox_KeyDown" />
                    <Button x:Name="GenerateButton" Grid.Column="1" Content="Generate" Width="140" Height="44" Margin="10,0,0,0" Click="GenerateButton_Click" Background="{StaticResource AccentGradientBrush}" Foreground="White" FontWeight="SemiBold" FontSize="13" CornerRadius="12" />
                </Grid>
                <Grid Grid.Row="1" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="100% local — nothing ever leaves this PC" Foreground="{StaticResource SubtleTextBrush}" FontSize="12" VerticalAlignment="Center" />
                    <ComboBox x:Name="StyleComboBox" Grid.Column="1" Width="170" Height="40" Margin="10,0,0,0" SelectedIndex="0" MaxDropDownHeight="800" ToolTipService.ToolTip="Style" SelectionChanged="StyleComboBox_SelectionChanged" DropDownOpened="ScrollableComboBox_DropDownOpened" BorderBrush="{StaticResource StyleAccentBrush}" BorderThickness="2">
                        <!-- MaxDropDownHeight is capped by the window's own height regardless of
                             this value (the popup can't extend past the bottom of the window this
                             ComboBox lives in) — the default ~50px-tall item row left several
                             entries scrolled off even at MaxDropDownHeight="800". A compact item
                             style fits all of them in the room actually available. -->
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Padding" Value="12,4" />
                                <Setter Property="MinHeight" Value="32" />
                            </Style>
                        </ComboBox.ItemContainerStyle>
                        <ComboBoxItem Content="Cartoon" />
                        <ComboBoxItem Content="Icon" />
                        <ComboBoxItem Content="Comic Book" />
                        <ComboBoxItem Content="Cel-Shaded" />
                        <ComboBoxItem Content="Anime" />
                        <ComboBoxItem Content="Watercolor" />
                        <ComboBoxItem Content="Oil Painting" />
                        <ComboBoxItem Content="Claymation" />
                        <ComboBoxItem Content="Fantasy Art" />
                        <ComboBoxItem Content="Pixel Art" />
                        <ComboBoxItem Content="3D Render" />
                        <ComboBoxItem Content="Photorealistic" />
                        <ComboBoxItem Content="Vintage Photo" />
                    </ComboBox>
                    <ComboBox x:Name="AspectComboBox" Grid.Column="2" Width="170" Height="40" Margin="10,0,0,0" SelectedIndex="0" ToolTipService.ToolTip="Aspect ratio" SelectionChanged="AspectComboBox_SelectionChanged">
                        <ComboBoxItem Content="Square" />
                        <ComboBoxItem Content="Landscape (16:9)" />
                        <ComboBoxItem Content="Portrait (9:16)" />
                        <ComboBoxItem Content="Landscape (4:3)" />
                        <ComboBoxItem Content="Portrait (3:4)" />
                    </ComboBox>
                    <ComboBox x:Name="ModelComboBox" Grid.Column="3" Width="190" Height="40" Margin="10,0,0,0" SelectedIndex="0" ToolTipService.ToolTip="Model">
                        <ComboBoxItem Content="DreamShaper XL (fast)" />
                        <ComboBoxItem Content="SDXL Base (standard)" />
                    </ComboBox>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,20,0,0">
            <!-- Fixed shares rather than */Auto: Results used to be an Auto row (sized to its
                 own content), which itself was sized off Preview's computed height — so each
                 one's resize retriggered a re-layout of the other, and the two settled on a far
                 too small value. Fixed shares of the same total remove that feedback loop. -->
            <Grid.RowDefinitions>
                <RowDefinition Height="5*" />
                <RowDefinition Height="2*" />
            </Grid.RowDefinitions>

            <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="20" Padding="20" Grid.Row="0">
                <Grid x:Name="PreviewCardGrid" SizeChanged="PreviewCardGrid_SizeChanged">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="RefPhotoColumn" Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition x:Name="PreviewImageColumn" Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="ImageRowDefinition" Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Reference Photo (optional)" FontSize="18" Foreground="White" FontWeight="SemiBold" Grid.Row="0" Grid.Column="0" />
                    <TextBlock Text="Preview" FontSize="18" Foreground="White" FontWeight="SemiBold" Grid.Row="0" Grid.Column="2" />

                    <Border x:Name="RefPhotoBorder" Background="#FF121116" CornerRadius="14" Margin="0,14,0,0" Grid.Row="1" Grid.Column="0" ToolTipService.ToolTip="Used as the base for your next generation">
                        <Grid>
                            <TextBlock x:Name="RefPhotoPlaceholderText" Text="No reference photo" Foreground="#FF55536A" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="12" />
                            <Image x:Name="RefPhotoThumbnail" Stretch="Uniform" />
                        </Grid>
                    </Border>

                    <Border x:Name="PreviewBorder" Background="#FF121116" CornerRadius="14" Margin="0,14,0,0" Grid.Row="1" Grid.Column="2">
                        <Grid>
                            <TextBlock x:Name="PreviewPlaceholderText" Text="Your image will appear here" Foreground="#FF55536A" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <!-- Stretched to fill the card (not centered at natural size) so the image renders as
                                 large as the available space allows; Stretch="Uniform" on the Image still preserves
                                 aspect ratio. The card itself is reshaped to match the selected aspect ratio (see
                                 UpdatePreviewAspect in code-behind), so this only letterboxes on the rare mismatch
                                 between an old result and a since-changed aspect selection. -->
                            <Button x:Name="PreviewImageButton" Background="Transparent" BorderThickness="0" Padding="0"
                                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"
                                    Click="PreviewImage_Click" ToolTipService.ToolTip="Click to copy to clipboard"
                                    PointerEntered="PreviewImageButton_PointerEntered" PointerExited="PreviewImageButton_PointerExited">
                                <!-- The default Button template swaps in a grey background on hover/press regardless of
                                     the Background set above; these resource overrides neutralize that, and the
                                     highlight border (toggled in code-behind) signals "click to copy" instead. -->
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent" />
                                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
                                </Button.Resources>
                                <Border x:Name="PreviewHoverBorder" BorderBrush="Transparent" BorderThickness="3" CornerRadius="14">
                                    <Image x:Name="PreviewImage" Stretch="Uniform" />
                                </Border>
                            </Button>
                            <Border x:Name="CopiedToast" Background="{StaticResource AccentGradientBrush}" CornerRadius="18" Padding="18,8"
                                    HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,16,0,0" Opacity="0" IsHitTestVisible="False">
                                <TextBlock Text="Copied!" Foreground="White" FontWeight="SemiBold" FontSize="14" />
                            </Border>
                        </Grid>
                    </Border>

                    <StackPanel Orientation="Vertical" Spacing="10" Margin="0,16,0,0" Grid.Row="2" Grid.Column="0">
                        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                            <Button x:Name="AddRefPhotoButton" Content="Add Reference Photo" Width="170" Height="44" Click="AddRefPhotoButton_Click" CornerRadius="10" ToolTipService.ToolTip="Use a photo from disk as the base for your next generation" />
                            <Button x:Name="ClearRefPhotoButton" Content="Clear Reference Photo" Width="170" Height="44" Click="ClearRefPhotoButton_Click" CornerRadius="10" IsEnabled="False" />
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Spacing="0" Margin="2,6,2,0">
                            <TextBlock Text="Creativity" FontSize="12" Foreground="{StaticResource SubtleTextBrush}" />
                            <Slider x:Name="CreativitySlider" Minimum="0.15" Maximum="0.9" StepFrequency="0.05" Value="0.45"
                                    ToolTipService.ToolTip="How much a result can differ from your reference photo — lower stays closer to the original, higher lets it reinvent more" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,16,0,0" Grid.Row="2" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Top">
                        <Button x:Name="CopyButton" Content="Copy to Clipboard" Width="170" Height="44" Click="CopyButton_Click" Background="{StaticResource AccentGradientBrush}" Foreground="White" FontWeight="SemiBold" CornerRadius="10" />
                        <Button x:Name="SaveButton" Content="Save as PNG" Width="140" Height="44" Click="SaveButton_Click" CornerRadius="10" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="ResultsCardBorder" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="20" Padding="16" Grid.Row="1" Margin="0,20,0,0" SizeChanged="ResultsCardBorder_SizeChanged">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition x:Name="ResultsSpacerColumn" Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Results — click to preview; use the ↻ badge to use one as your reference photo" FontSize="14" Foreground="{StaticResource SubtleTextBrush}" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Jeff Molofee (NeHe) 2026" FontSize="12" Foreground="{StaticResource SubtleTextBrush}" HorizontalAlignment="Right" />

                    <!-- To the right of the result thumbnails — same spot the credit line used
                         to float in on its own, now sharing that otherwise-empty space. -->
                    <!-- Fixed 16:9 size and pinned to the right edge (not Stretch) so it stays
                         put regardless of the Aspect dropdown or window size — unlike the Ref
                         Photo/Preview/Results boxes, which are deliberately reshaped by those. -->
                    <Border x:Name="StyleDescriptionBorder" Background="#FF121116" BorderBrush="{StaticResource StyleAccentBrush}" BorderThickness="2" CornerRadius="14" Margin="0,14,0,0" Grid.Row="1" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <TextBlock x:Name="StyleDescriptionText" Foreground="#FF9A99AC" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="10" />
                    </Border>

                    <ItemsControl x:Name="ResultsPanel" Grid.Row="1" Grid.Column="0" Margin="0,14,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="12" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:ResultItem">
                                <Grid Width="160" Height="160">
                                    <Border BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="14" Background="{StaticResource ResultSlotBackgroundBrush}">
                                        <Grid>
                                            <TextBlock Text="+" FontSize="32" Foreground="#FF6A6A6A" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            <Button Tag="{x:Bind}" Click="ResultSlot_Click" Background="Transparent" BorderThickness="0" Padding="0"
                                                    HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"
                                                    ToolTipService.ToolTip="Click to preview">
                                                <Button.Resources>
                                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent" />
                                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent" />
                                                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                                                    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
                                                </Button.Resources>
                                                <Image Source="{x:Bind Thumbnail, Mode=OneWay}" Stretch="UniformToFill" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                    <!-- Highlights the whole thumbnail, not just the badge below, when this image is
                                         selected as the next generation's img2img base — a border-color change on a
                                         34px badge alone was easy to miss entirely. Transparent (invisible) when not
                                         active, so it has no effect on the normal appearance of a result slot. -->
                                    <Border BorderBrush="{x:Bind ActiveBrush, Mode=OneWay}" BorderThickness="3" CornerRadius="14" IsHitTestVisible="False" />
                                    <!-- Deliberately separate from the preview click above: this is the only control
                                         that can carry an image forward as the next generate's img2img base. Preview
                                         alone must never select a base image, or every later prompt silently keeps
                                         the shape of whatever was last clicked (this is what "always a butt" was). -->
                                    <Button Tag="{x:Bind}" Click="ResultSlot_ToggleBase_Click" Width="34" Height="34" Padding="0"
                                            CornerRadius="17" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,8,8"
                                            IsEnabled="{x:Bind HasImage, Mode=OneWay}"
                                            Background="#CC1B1A22" BorderBrush="{x:Bind ActiveBrush, Mode=OneWay}" BorderThickness="2"
                                            Content="&#x21BB;" FontSize="16" Foreground="White"
                                            ToolTipService.ToolTip="{x:Bind Hint, Mode=OneWay}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
