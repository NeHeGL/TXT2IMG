<Application
    x:Class="TXT2IMG.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF8C6CFF" Offset="0" />
                <GradientStop Color="#FF35D6C4" Offset="1" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="TitleGradientBrush" StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#FFA98CFF" Offset="0" />
                <GradientStop Color="#FF4DE0CC" Offset="1" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FF201F27" />
            <SolidColorBrush x:Key="CardBorderBrush" Color="#FF37364A" />
            <SolidColorBrush x:Key="SubtleTextBrush" Color="#FFAFAEC0" />
            <SolidColorBrush x:Key="ResultSlotBackgroundBrush" Color="#FF17161D" />
            <!-- The purple from AccentGradientBrush, pulled out as a solid color — shared by the
                 Style dropdown and its description panel (in the Results card, far away on
                 screen) so the color itself signals they're related, since proximity can't. -->
            <SolidColorBrush x:Key="StyleAccentBrush" Color="#FF8C6CFF" />

            <Style x:Key="ResultSlotButtonStyle" TargetType="Button">
                <Setter Property="Padding" Value="4" />
                <Setter Property="Background" Value="{StaticResource ResultSlotBackgroundBrush}" />
                <Setter Property="BorderThickness" Value="3" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
